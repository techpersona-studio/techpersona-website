---
import type { WordPressPost } from "../../lib/wordpress";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogDiscussion from "../../components/BlogDiscussion.astro";
import {
  formatPostDate,
  getAuthorName,
  getCommentsForPost,
  getPostsForNavigation,
  cleanArticle,
  cleanInline,
  cleanText,
  getWordPressCommentActionUrl,
  getWordPressCommentsApiUrl,
  getFeaturedImageAlt,
  getFeaturedImageUrl,
  getPosts,
  stripHtml,
} from "../../lib/wordpress";

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: WordPressPost;
}

const { post } = Astro.props;
const imageUrl = getFeaturedImageUrl(post);
const imageAlt = getFeaturedImageAlt(post);
const author = getAuthorName(post);
const description = cleanText(post.excerpt.rendered);
const title = cleanText(post.title.rendered);
const comments = await getCommentsForPost(post.id);
const navigationPosts = await getPostsForNavigation();
const currentPostIndex = navigationPosts.findIndex((navigationPost) => navigationPost.id === post.id);
const previousPost = currentPostIndex > 0 ? navigationPosts[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex >= 0 && currentPostIndex < navigationPosts.length - 1
    ? navigationPosts[currentPostIndex + 1]
    : null;
const authorBio =
  "Thao Phuong, founder of TechPersona Studio — a solo web designer in Worcester, MA building websites and lead automation for local service businesses.";
const commentsApiUrl = getWordPressCommentsApiUrl(post.id);
const commentActionUrl = getWordPressCommentActionUrl();
---

<BaseLayout title={title + " | TechPersona Studio"} description={description} image={imageUrl} type="article">
  <article class="section-band bg-[var(--paper)]">
    <div class="page-shell-narrow">
      <header>
        <a href="/blog" class="text-sm font-semibold text-[var(--pine)] hover:text-[var(--pine-soft)]">
          Back to blog
        </a>
        <div class="mt-6 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs font-semibold uppercase tracking-[0.2em] text-[var(--ink-faint)]">
          <time datetime={post.date}>{formatPostDate(post.date)}</time>
          {author && <span>By {author}</span>}
        </div>
        <h1
          class="mt-4 text-4xl font-extrabold leading-[1.02] tracking-[-0.045em] text-[var(--ink)] sm:text-5xl lg:text-6xl"
          set:html={cleanInline(post.title.rendered)}
        />
        <p class="mt-5 max-w-[60ch] text-lg leading-relaxed text-[var(--ink-soft)]">
          {description}
        </p>
      </header>

      {imageUrl && (
        <div class="double-shell mt-10">
          <div class="double-shell__inner">
            <img
              src={imageUrl}
              alt={imageAlt || title}
              class="aspect-[16/10] w-full object-cover"
            />
          </div>
        </div>
      )}

      <div class="article-content mt-10" set:html={cleanArticle(post.content.rendered)} />

      {(previousPost || nextPost) && (
        <nav
          aria-label="Post navigation"
          class="mt-14 border-t border-[var(--hair)] pt-8 sm:pt-10"
        >
          <div class:list={["grid gap-4", previousPost && nextPost ? "md:grid-cols-2" : "md:grid-cols-1"]}>
            {previousPost && (
              <a
                href={`/blog/${previousPost.slug}`}
                class="block rounded-[1.5rem] border border-[var(--hair)] bg-[var(--core)] px-5 py-5 transition-colors hover:border-[rgba(30,58,52,0.2)] hover:bg-[var(--paper-deep)] sm:px-6"
              >
                <p class="text-[0.7rem] font-semibold uppercase tracking-[0.2em] text-[var(--ink-faint)]">
                  Previous post
                </p>
                <h2
                  class="mt-3 text-xl font-semibold leading-snug text-[var(--ink)] sm:text-2xl"
                  set:html={cleanInline(previousPost.title.rendered)}
                />
              </a>
            )}

            {nextPost && (
              <a
                href={`/blog/${nextPost.slug}`}
                class:list={[
                  "block rounded-[1.5rem] border border-[var(--hair)] bg-[var(--core)] px-5 py-5 transition-colors hover:border-[rgba(30,58,52,0.2)] hover:bg-[var(--paper-deep)] sm:px-6",
                  previousPost ? "md:text-right" : "md:justify-self-end md:max-w-[22rem] md:text-right",
                ]}
              >
                <p class="text-[0.7rem] font-semibold uppercase tracking-[0.2em] text-[var(--ink-faint)]">
                  Next post
                </p>
                <h2
                  class="mt-3 text-xl font-semibold leading-snug text-[var(--ink)] sm:text-2xl"
                  set:html={cleanInline(nextPost.title.rendered)}
                />
              </a>
            )}
          </div>
        </nav>
      )}

      <BlogDiscussion
        title={title}
        pageUrl={Astro.url.href}
        authorName={author ?? "TechPersona Studio"}
        authorBio={authorBio}
        comments={comments}
        commentsApiUrl={commentsApiUrl}
        commentActionUrl={commentActionUrl}
        postId={post.id}
      />
    </div>
  </article>
</BaseLayout>
