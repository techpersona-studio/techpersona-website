---
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--hair)] bg-[var(--paper-deep)]">
  <div class="page-shell py-10 sm:py-12">
    <p class="text-lg font-semibold tracking-[-0.03em] text-[var(--ink)]">TechPersona Studio</p>
    <p class="mt-2 max-w-xl text-sm leading-relaxed text-[var(--ink-soft)]">
      Notes on website redesign, lead automation, and local search for service businesses in Worcester, MA.
    </p>
    <p class="mt-6 text-xs tracking-[0.16em] text-[var(--ink-faint)]">
      &copy; {year} TechPersona Studio &middot; <a href="/" class="hover:text-[var(--ink)]">techpersonastudio.com</a>
    </p>
  </div>
</footer>
