---
import type { WordPressComment } from "../lib/wordpress";
import { formatPostDate } from "../lib/wordpress";

interface Props {
  title: string;
  pageUrl: string;
  authorName: string;
  authorBio: string;
  comments: WordPressComment[];
  commentsApiUrl: string;
  commentActionUrl: string;
  postId: number;
}

const {
  title,
  pageUrl,
  authorName,
  authorBio,
  comments,
  commentsApiUrl,
  commentActionUrl,
  postId,
} = Astro.props;

---

<section class="mt-16 border-t border-[var(--hair)] pt-12 sm:mt-20 sm:pt-16" aria-labelledby="discussion-heading">
  <div class="flex flex-col gap-8">
    <header class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-[var(--ink-faint)]">
          Community
        </p>
        <h2 id="discussion-heading" class="mt-2 text-3xl font-bold tracking-[-0.04em] text-[var(--ink)] sm:text-4xl">
          Comments
        </h2>
      </div>
      <p class="max-w-[34ch] text-sm leading-relaxed text-[var(--ink-soft)]">
        Native WordPress comments, rendered in Astro and submitted back to WordPress without leaving the page.
      </p>
    </header>

    <div class="grid gap-5 lg:grid-cols-[1.08fr_0.92fr]">
      <section class="rounded-[1.75rem] border border-[var(--hair)] bg-[var(--core)] p-5 shadow-[0_14px_40px_-30px_rgba(30,58,52,0.35)] sm:p-6">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-[var(--ink-faint)]">
          Written by
        </p>
        <div class="mt-4 flex items-start gap-4">
          <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-[1.1rem] bg-[linear-gradient(135deg,#e9ddd2_0%,#d7e5df_100%)] text-sm font-bold tracking-[-0.04em] text-[var(--ink)]">
            {authorName
              .split(" ")
              .filter(Boolean)
              .slice(0, 2)
              .map((part) => part[0]?.toUpperCase())
              .join("")}
          </div>
          <div class="min-w-0">
            <h3 class="text-xl font-semibold tracking-[-0.03em] text-[var(--ink)] sm:text-[1.45rem]">
              {authorName}
            </h3>
            <p class="mt-1 max-w-[48ch] text-sm leading-relaxed text-[var(--ink-soft)]">
              {authorBio}
            </p>
          </div>
        </div>
      </section>

      <section class="rounded-[1.75rem] border border-[var(--hair)] bg-[var(--core)] p-5 shadow-[0_14px_40px_-30px_rgba(30,58,52,0.35)] sm:p-6">
        <div class="flex items-center justify-between gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-[var(--ink-faint)]">
              Share this post
            </p>
            <p class="mt-2 text-sm leading-relaxed text-[var(--ink-soft)]">
              Copy the link and send it anywhere.
            </p>
          </div>
        </div>

        <div class="mt-5 flex flex-wrap items-center gap-3">
          <button
            type="button"
            class="inline-flex items-center gap-2 rounded-full border border-[var(--hair)] bg-white px-4 py-2.5 text-sm font-semibold text-[var(--ink)] transition hover:-translate-y-0.5 hover:border-[rgba(30,58,52,0.2)] hover:text-[var(--pine)]"
            data-copy-link
          >
            Copy link
          </button>
          <p class="text-sm text-[var(--ink-faint)]" data-copy-status aria-live="polite">
            {pageUrl}
          </p>
        </div>
      </section>
    </div>

    <section class="rounded-[1.75rem] border border-[var(--hair)] bg-[var(--paper-deep)] p-5 sm:p-6">
      <form
        class="space-y-4"
        action={commentActionUrl}
        method="post"
        target="wp-comment-target"
        data-comment-form
      >
        <input type="hidden" name="comment_post_ID" value={postId} />
        <input type="hidden" name="comment_parent" value="0" />
        <input type="hidden" name="redirect_to" value={pageUrl} />
        <iframe name="wp-comment-target" title="WordPress comment submission target" class="hidden" aria-hidden="true"></iframe>

        <div class="flex items-start gap-4">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-[1rem] bg-[var(--core)] text-sm font-semibold tracking-[-0.03em] text-[var(--ink)] shadow-[0_10px_24px_-18px_rgba(30,58,52,0.4)]">
            DC
          </div>
          <div class="min-w-0 flex-1">
            <label for="comment" class="text-sm font-semibold text-[var(--ink)]">
              Leave a comment
            </label>
            <textarea
              id="comment"
              name="comment"
              rows="4"
              class="mt-3 w-full rounded-[1.25rem] border border-[var(--hair)] bg-white px-4 py-4 text-base leading-relaxed text-[var(--ink)] placeholder:text-[var(--ink-faint)] shadow-[inset_0_1px_0_rgba(255,255,255,0.7)] outline-none transition focus:border-[rgba(30,58,52,0.28)] focus:ring-2 focus:ring-[rgba(30,58,52,0.12)]"
              placeholder="Share a thought, a tip, or a variation you would try."
              required
            ></textarea>

            <div class="mt-4 grid gap-3 sm:grid-cols-3">
              <input
                type="text"
                name="author"
                class="w-full rounded-full border border-[var(--hair)] bg-white px-4 py-3 text-sm text-[var(--ink)] outline-none transition placeholder:text-[var(--ink-faint)] focus:border-[rgba(30,58,52,0.28)] focus:ring-2 focus:ring-[rgba(30,58,52,0.12)]"
                placeholder="Name"
                required
              />
              <input
                type="email"
                name="email"
                class="w-full rounded-full border border-[var(--hair)] bg-white px-4 py-3 text-sm text-[var(--ink)] outline-none transition placeholder:text-[var(--ink-faint)] focus:border-[rgba(30,58,52,0.28)] focus:ring-2 focus:ring-[rgba(30,58,52,0.12)]"
                placeholder="Email"
                required
              />
            </div>

            <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
              <p class="text-sm leading-relaxed text-[var(--ink-faint)]" data-comment-status aria-live="polite">
                Comments are stored in WordPress. The page will refresh the thread from the CMS after submission.
              </p>
              <button
                type="submit"
                data-comment-submit
                class="inline-flex items-center justify-center rounded-full bg-[var(--pine)] px-5 py-2.5 text-sm font-semibold text-[var(--paper)] transition hover:-translate-y-0.5 hover:bg-[var(--pine-soft)]"
              >
                Post comment
              </button>
            </div>
          </div>
        </div>
      </form>
    </section>

    <ol
      class="space-y-4"
      aria-label="Reader comments"
      data-comments-list
      data-comments-api={commentsApiUrl}
    >
      {comments.map((comment) => (
        <li class="rounded-[1.75rem] border border-[var(--hair)] bg-[var(--core)] p-5 shadow-[0_14px_40px_-32px_rgba(30,58,52,0.35)] sm:p-6">
          <article class="flex gap-4">
            {comment.author_avatar_urls?.["96"] ? (
              <img
                src={comment.author_avatar_urls["96"]}
                alt={comment.author_name}
                class="h-12 w-12 shrink-0 rounded-[1rem] object-cover"
                loading="lazy"
              />
            ) : (
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-[1rem] bg-[linear-gradient(135deg,#e9ddd2_0%,#d7e5df_100%)] text-sm font-bold tracking-[-0.04em] text-[var(--ink)]">
                {comment.author_name
                  .split(" ")
                  .filter(Boolean)
                  .slice(0, 2)
                  .map((part) => part[0]?.toUpperCase())
                  .join("")}
              </div>
            )}
            <div class="min-w-0 flex-1">
              <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                <h3 class="text-base font-semibold tracking-[-0.02em] text-[var(--ink)]">
                  {comment.author_name}
                </h3>
                <time class="text-sm text-[var(--ink-faint)]" datetime={comment.date}>
                  {formatPostDate(comment.date)}
                </time>
              </div>
              <div class="article-content mt-3 max-w-[62ch] text-sm" set:html={comment.content.rendered} />
              <div class="mt-4 flex items-center gap-4 text-sm font-semibold text-[var(--ink-faint)]">
                <a href={comment.link ?? pageUrl} class="transition hover:text-[var(--pine)]">
                  Reply
                </a>
              </div>
            </div>
          </article>
        </li>
      ))}
    </ol>
  </div>
</section>

<script type="module" define:vars={{ pageUrl }}>
  const commentsList = document.querySelector("[data-comments-list]");
  const commentForm = document.querySelector("[data-comment-form]");
  const commentStatus = document.querySelector("[data-comment-status]");
  const commentSubmit = document.querySelector("[data-comment-submit]");
  const copyLinkButton = document.querySelector("[data-copy-link]");
  const copyLinkStatus = document.querySelector("[data-copy-status]");
  const commentFrame = document.querySelector('iframe[name="wp-comment-target"]');
  let hasSubmitted = false;

  const refreshComments = () => {
    if (!commentsList) return;

    const commentsApi = commentsList.getAttribute("data-comments-api");

    if (!commentsApi) return;

    fetch(commentsApi)
      .then((response) => (response.ok ? response.json() : []))
      .then((items) => {
        if (!Array.isArray(items) || items.length === 0) return;

        commentsList.innerHTML = items
          .map((comment) => {
            const avatar = comment?.author_avatar_urls?.["96"];
            const name = comment?.author_name ?? "Reader";
            const date = comment?.date ?? "";
            const content = comment?.content?.rendered ?? "";
            const initials = name
              .split(" ")
              .filter(Boolean)
              .slice(0, 2)
              .map((part) => part[0]?.toUpperCase())
              .join("");

            return `
              <li class="rounded-[1.75rem] border border-[var(--hair)] bg-[var(--core)] p-5 shadow-[0_14px_40px_-32px_rgba(30,58,52,0.35)] sm:p-6">
                <article class="flex gap-4">
                  ${
                    avatar
                      ? `<img src="${avatar}" alt="${name}" class="h-12 w-12 shrink-0 rounded-[1rem] object-cover" loading="lazy" />`
                      : `<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-[1rem] bg-[linear-gradient(135deg,#e9ddd2_0%,#d7e5df_100%)] text-sm font-bold tracking-[-0.04em] text-[var(--ink)]">${initials}</div>`
                  }
                  <div class="min-w-0 flex-1">
                    <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                      <h3 class="text-base font-semibold tracking-[-0.02em] text-[var(--ink)]">${name}</h3>
                      <time class="text-sm text-[var(--ink-faint)]" datetime="${date}">${new Date(date).toLocaleDateString(
                        "en-US",
                        { year: "numeric", month: "long", day: "numeric" },
                      )}</time>
                    </div>
                    <div class="article-content mt-3 max-w-[62ch] text-sm">${content}</div>
                    <div class="mt-4 flex items-center gap-4 text-sm font-semibold text-[var(--ink-faint)]">
                      <a href="${comment?.link ?? pageUrl}" class="transition hover:text-[var(--pine)]">Reply</a>
                    </div>
                  </div>
                </article>
              </li>
            `;
          })
          .join("");
      })
      .catch(() => {
        // Keep the server-rendered comments when WordPress is unavailable.
      });
  };

  refreshComments();

  if (commentForm) {
    commentForm.addEventListener("submit", () => {
      hasSubmitted = true;
      if (commentStatus) {
        commentStatus.textContent = "Sending your comment to WordPress...";
      }
      if (commentSubmit) {
        commentSubmit.disabled = true;
        commentSubmit.textContent = "Sending...";
      }

      window.setTimeout(() => {
        refreshComments();
      }, 1500);
    });
  }

  if (commentFrame) {
    commentFrame.addEventListener("load", () => {
      if (!hasSubmitted) return;

      hasSubmitted = false;

      if (commentStatus) {
        commentStatus.textContent =
          "Comment sent to WordPress. It may appear after moderation.";
      }
      if (commentSubmit) {
        commentSubmit.disabled = false;
        commentSubmit.textContent = "Post comment";
      }
      if (commentForm instanceof HTMLFormElement) {
        commentForm.reset();
      }

      refreshComments();
    });
  }

  if (copyLinkButton && copyLinkStatus) {
    copyLinkButton.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(pageUrl);
        copyLinkStatus.textContent = "Link copied.";
      } catch {
        copyLinkStatus.textContent = pageUrl;
      }
    });
  }
</script>
