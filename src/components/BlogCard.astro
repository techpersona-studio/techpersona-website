---
import type { WordPressPost } from "../lib/wordpress";
import {
  formatPostDate,
  getAuthorName,
  getFeaturedImageAlt,
  getFeaturedImageUrl,
  cleanInline,
  cleanText,
} from "../lib/wordpress";

interface Props {
  post: WordPressPost;
}

const { post } = Astro.props;
const imageUrl = getFeaturedImageUrl(post);
const imageAlt = getFeaturedImageAlt(post);
const author = getAuthorName(post);
const excerpt = cleanText(post.excerpt.rendered);
const titleHtml = cleanInline(post.title.rendered);
---

<article class="double-shell group h-full">
  <a href={"/blog/" + post.slug} class="double-shell__inner block h-full overflow-hidden">
    {imageUrl ? (
      <img
        src={imageUrl}
        alt={imageAlt || cleanText(post.title.rendered)}
        class="aspect-[4/3] w-full object-cover transition duration-300 group-hover:scale-[1.02]"
        loading="lazy"
      />
    ) : (
      <div class="flex aspect-[4/3] items-center justify-center bg-[var(--pine-wash)] text-sm font-medium text-[var(--ink-faint)]">
        No featured image
      </div>
    )}
    <div class="flex h-full flex-col p-5 sm:p-6">
      <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs font-medium uppercase tracking-[0.2em] text-[var(--ink-faint)]">
        <time datetime={post.date}>
          {formatPostDate(post.date)}
        </time>
        {author && <span class="text-[var(--ink-faint)]">By {author}</span>}
      </div>
      <h2
        class="mt-4 text-2xl font-bold leading-tight tracking-[-0.03em] text-[var(--ink)] transition-colors duration-150 group-hover:text-[var(--pine)]"
        set:html={titleHtml}
      />
      <p class="mt-3 text-sm leading-relaxed text-[var(--ink-soft)]">{excerpt}</p>
      <p class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-[var(--pine)]">
        Read post
        <span class="transition-transform duration-150 group-hover:translate-x-0.5">→</span>
      </p>
    </div>
  </a>
</article>
