---
// Blog header mirrors the homepage nav (same links, same pine CTA) and the
// same mobile pattern: links collapse into a burger that opens a slide-in
// overlay at <=860px. Section links point at the homepage anchors so a
// reader on any /blog page can jump back into the funnel.
const navItems = [
  { href: "/#services", label: "What I build" },
  { href: "/#work", label: "Real work" },
  { href: "/#about", label: "About" },
  { href: "/#faq", label: "FAQ" },
  { href: "/blog", label: "Blog" },
];
---

<header class="sticky top-0 z-[200] border-b border-[var(--hair)] bg-[var(--paper)]">
  <div class="page-shell flex items-center gap-6 py-4">
    <a href="/" class="text-xl font-bold tracking-[-0.04em] text-[var(--ink)] sm:text-2xl">
      TechPersona <span class="text-[var(--pine)]">Studio</span>
    </a>

    <!-- Desktop nav -->
    <nav aria-label="Main navigation" class="nav-desktop">
      <ul class="flex items-center gap-7 text-sm font-medium text-[var(--ink-soft)]">
        {navItems.map((item) => (
          <li>
            <a href={item.href} class="transition-colors duration-150 hover:text-[var(--ink)]">
              {item.label}
            </a>
          </li>
        ))}
      </ul>
      <a href="/#audit" class="island-btn island-btn--pine">
        Get my free website audit
        <span class="island-btn__icon" aria-hidden="true">&#8594;</span>
      </a>
    </nav>

    <!-- Mobile burger -->
    <button
      type="button"
      class="nav-burger"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="blogNavOverlay"
      data-nav-burger
    >
      <span class="bl"></span>
      <span class="bl"></span>
    </button>
  </div>
</header>

<!-- Mobile slide-in overlay -->
<div class="nav-overlay" id="blogNavOverlay" aria-hidden="true" data-nav-overlay>
  {navItems.map((item) => (
    <a href={item.href} class="ov-link">{item.label}</a>
  ))}
  <div class="ov-foot">
    <a href="/#audit" class="island-btn island-btn--pine">
      Get my free website audit
      <span class="island-btn__icon" aria-hidden="true">&#8594;</span>
    </a>
    <a href="tel:+18578002667" class="ov-tel">+1 857 800 2667</a>
  </div>
</div>

<style>
  /* Desktop nav — shown by default, hidden on mobile (matches landing) */
  .nav-desktop {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }

  /* Burger — hidden on desktop, shown on mobile; bars→X animation */
  .nav-burger {
    display: none;
    margin-left: auto;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }
  .nav-burger .bl {
    width: 24px;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
    transition: transform 260ms cubic-bezier(0.22, 1, 0.36, 1), opacity 260ms ease;
  }
  .nav-burger[aria-expanded="true"] .bl:nth-child(1) { transform: translateY(3.5px) rotate(45deg); }
  .nav-burger[aria-expanded="true"] .bl:nth-child(2) { transform: translateY(-3.5px) rotate(-45deg); }

  /* Overlay — same top-aligned layout + slide-in as the homepage */
  .nav-overlay {
    position: fixed;
    inset: 0;
    z-index: 190;
    background: var(--paper);
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 2rem;
    padding: clamp(96px, 15vh, 140px) clamp(24px, 7vw, 48px) 2rem;
    transform: translateX(100%);
    transition: transform 260ms cubic-bezier(0.22, 1, 0.36, 1);
    visibility: hidden;
  }
  .nav-overlay.open {
    transform: translateX(0);
    visibility: visible;
  }
  .nav-overlay .ov-link {
    font-size: 1.9rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--ink);
    text-decoration: none;
  }
  .nav-overlay .ov-foot {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }
  .nav-overlay .ov-tel {
    color: var(--ink-soft);
    font-weight: 600;
    text-decoration: none;
  }
  @media (min-width: 860px) {
    .nav-overlay { display: none; }
  }
  @media (max-width: 860px) {
    .nav-desktop { display: none; }
    .nav-burger { display: flex; }
  }
</style>

<script>
  const burger = document.querySelector("[data-nav-burger]");
  const overlay = document.querySelector("[data-nav-overlay]");

  if (burger && overlay) {
    const close = () => {
      overlay.classList.remove("open");
      overlay.setAttribute("aria-hidden", "true");
      burger.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";
    };

    burger.addEventListener("click", () => {
      const open = overlay.classList.toggle("open");
      overlay.setAttribute("aria-hidden", String(!open));
      burger.setAttribute("aria-expanded", String(open));
      document.body.style.overflow = open ? "hidden" : "";
    });

    overlay.querySelectorAll("a").forEach((a) => a.addEventListener("click", close));
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") close();
    });
  }
</script>
